[Unit]
Description=LLM Gateway — API gateway (:8900)
After=default.target llm-litellm.service

[Service]
Type=simple
WorkingDirectory=/home/derek/Projects/llm-gateway
EnvironmentFile=-/home/derek/Projects/llm-gateway/gateway.env
ExecStart=/home/derek/Projects/llm-gateway/run_gateway.sh
Restart=on-failure
RestartSec=10
TimeoutStartSec=60
TimeoutStopSec=15
StandardOutput=append:/home/derek/Projects/llm-gateway/logs/gateway.log
StandardError=append:/home/derek/Projects/llm-gateway/logs/gateway.log

[Install]
WantedBy=default.target
