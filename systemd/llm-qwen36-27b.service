[Unit]
Description=LLM Gateway — Qwen3.6-27B NVFP4+MTP vLLM (:9002, GPU 0)
After=network.target

[Service]
Type=simple
User=derek
Group=derek
WorkingDirectory=/home/derek/Projects/llm-gateway
EnvironmentFile=-/home/derek/Projects/llm-gateway/gateway.env
ExecStart=/home/derek/Projects/llm-gateway/run_qwen36_27b.sh
Restart=on-failure
RestartSec=60
TimeoutStartSec=600
TimeoutStopSec=60
StandardOutput=append:/home/derek/Projects/llm-gateway/logs/qwen36_27b.log
StandardError=append:/home/derek/Projects/llm-gateway/logs/qwen36_27b.log

[Install]
WantedBy=multi-user.target
