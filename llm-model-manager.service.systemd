[Unit]
Description=LLM Gateway — model_manager (spawns/unloads vLLM on demand, :8002)
After=network.target

[Service]
Type=simple
User=derek
Group=derek
WorkingDirectory=/home/derek/Projects/llm-gateway
EnvironmentFile=-/home/derek/Projects/llm-gateway/gateway.env

# Defensive cleanup before each start: kill any orphan model_manager.py
# processes that survived a previous unclean shutdown (the "mm zombie"
# pattern), and reset the unit's failed state so systemctl start works
# from any prior state.  Both lines use `-` prefix (failures don't block
# start) and `+` prefix on the systemctl call (run as root regardless of
# User= so reset-failed has permission).
ExecStartPre=-/usr/bin/pkill -KILL -f /home/derek/Projects/llm-gateway/model_manager.py
ExecStartPre=+-/usr/bin/systemctl reset-failed llm-model-manager.service

ExecStart=/home/derek/Projects/llm-gateway/run_model_manager.sh

# KillMode=process: only kill MainPID on stop, leave vLLM children to be
# adopted on next start (paired with adopt_existing_backends).
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=120
Restart=on-failure
RestartSec=10
TimeoutStartSec=30
StandardOutput=append:/home/derek/Projects/llm-gateway/logs/model_manager.log
StandardError=append:/home/derek/Projects/llm-gateway/logs/model_manager.log

[Install]
WantedBy=multi-user.target
